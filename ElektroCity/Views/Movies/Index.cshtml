@model IEnumerable<ElektroCity.Models.Movie>

@{
    ViewData["Title"] = "Админ Панел - Филми";
}

<div class="container my-5 text-light">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-uppercase text-warning">🎬 Управление на филми</h1>
            <p class="text-muted mb-0">Администраторски панел за добавяне, редакция и изтриване</p>
        </div>
        <a href="/Movies/Create" class="btn btn-success fw-bold px-4 py-2 shadow">+ Добави Нов Филм</a>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0 text-white">
                    <thead class="table-secondary text-uppercase fs-7" style="background-color: #222;">
                        <tr>
                            <th class="ps-4">Постер</th>
                            <th>Заглавие</th>
                            <th>Жанр</th>
                            <th>Времетраене</th>
                            <th class="text-end pe-4">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        Няма намерени филми в базата данни.
                                    </td>
                                </tr>
                        }
                        @foreach (var item in Model)
                        {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <img src="@item.ImageUrl" alt="Постер" class="rounded border border-secondary" style="width: 50px; height: 70px; object-fit: cover;" onerror="this.src='https://placehold.co/50x70/333/fff?text=No+Image'">
                                    </td>
                                    <td class="fw-bold text-warning fs-5">@item.Title</td>
                                    <td><span class="badge bg-secondary">@item.Genre</span></td>
                                    <td>⏱️ @item.DurationMinutes мин.</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="/Movies/Edit/@item.Id" class="btn btn-outline-info fw-bold">Промени</a>
                                            <a href="/Movies/Details/@item.Id" class="btn btn-outline-light">Детайли</a>
                                            <a href="/Movies/Delete/@item.Id" class="btn btn-danger fw-bold">❌ Изтрий</a>
                                        </div>
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>