@model ElektroCity.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-5 text-white fade-in">
    <div class="mb-4">
        <a asp-action="Index" class="text-warning text-decoration-none fw-semibold small tracking-wide text-uppercase">
            <i class="bi bi-chevron-left"></i> Обратно към филмите
        </a>
    </div>

    <div class="row g-5">
        <div class="col-lg-4 col-md-5">
            <div class="position-relative movie-poster-container">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-4 shadow-2-strong main-poster" />
                }
                else
                {
                        <div class="bg-dark rounded-4 d-flex align-items-center justify-content-center shadow-lg border border-secondary" style="height: 500px;">
                            <span class="text-muted">Няма наличен постер</span>
                        </div>
                }
                <div class="poster-glow"></div>
            </div>
        </div>

        <div class="col-lg-8 col-md-7">
            <span class="badge bg-warning text-dark fw-bold text-uppercase px-3 py-2 mb-3 tracking-wider rounded-pill">
                @Model.Genre
            </span>
            <h1 class="display-4 fw-black text-white text-uppercase mb-2 heading-style">@Model.Title</h1>

            <div class="d-flex align-items-center gap-3 mb-4 text-muted small">
                <span><i class="bi bi-clock-history text-warning me-1"></i> @Model.DurationMinutes мин.</span>
                <span>•</span>
                <span class="text-success fw-bold"><i class="bi bi-lightning-charge-fill"></i> HD / Dolby Atmos</span>
            </div>

            <h5 class="text-warning text-uppercase tracking-wider fw-bold mb-3 border-bottom border-dark pb-2">Синопсис</h5>
            <p class="text-secondary mb-5 description-text">
                @Model.Description
            </p>

            <div class="premium-showtime-card p-4 rounded-4">
                <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
                    <h4 class="text-white text-uppercase tracking-widest fw-bold m-0 fs-5">
                        <span class="text-warning">||</span> Избери дата и час на прожекция
                    </h4>
                    <div class="d-flex align-items-center gap-3">
                        <a asp-controller="Screenings" asp-action="Create" class="btn btn-outline-warning btn-sm rounded-pill px-3">
                            <i class="bi bi-plus-circle"></i> Добави нов час / прожекция
                        </a>
                        <span class="badge bg-dark border border-secondary text-muted px-3 py-2 rounded-3">
                            @((Model.Screenings?.Count ?? 0)) налични
                        </span>
                    </div>
                </div>

                @if (Model.Screenings != null && Model.Screenings.Any())
                {
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                        @foreach (var screening in Model.Screenings.OrderBy(s => s.Showtime))
                        {
                                    <div class="col">
                                        <a asp-controller="Reservation" asp-action="ChooseSeats" asp-route-id="@screening.Id" class="showtime-ticket-btn">
                                            <div class="ticket-header">
                                                <span class="time-display">@screening.Showtime.ToString("HH:mm")</span>
                                                <span class="hall-badge">@screening.HallName</span>
                                            </div>
                                            <div class="ticket-footer">
                                                <div class="date-display">
                                                    <i class="bi bi-calendar3 me-1"></i> @screening.Showtime.ToString("dd MMM (ddd)")
                                                </div>
                                                <div class="price-display">
                                            @screening.TicketPrice.ToString("0.00") лв.
                                                </div>
                                            </div>
                                            <div class="ticket-cutout-left"></div>
                                            <div class="ticket-cutout-right"></div>
                                        </a>
                                    </div>
                        }
                        </div>
                }
                else
                {
                        <div class="text-center py-5 text-muted bg-opacity-10 bg-light rounded-4 border border-dashed border-secondary">
                            <i class="bi bi-calendar-x display-5 mb-3 text-secondary d-block"></i>
                            <p class="m-0 mb-2">Няма програмирани прожекции за този филм.</p>
                            <a asp-controller="Screenings" asp-action="Create" class="btn btn-outline-warning btn-sm rounded-pill px-3 mt-2">
                                <i class="bi bi-plus-circle"></i> Добави нов час / прожекция
                            </a>
                        </div>
                }
            </div>

            <div class="mt-4 d-flex gap-2 justify-content-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark border-secondary btn-sm text-muted rounded-pill px-3">
                    <i class="bi bi-pencil-square"></i> Редактирай филм
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap');

    body {
        background-color: #0b0c10 !important;
        font-family: 'Montserrat', sans-serif;
    }

    .fw-black { font-weight: 900; }
    .tracking-widest { letter-spacing: 2px; }
    .tracking-wider { letter-spacing: 1px; }

    /* Ефекти на постера */
    .movie-poster-container {
        position: relative;
        z-index: 1;
    }
    .main-poster {
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .movie-poster-container:hover .main-poster {
        transform: scale(1.02) translateY(-5px);
    }
    .poster-glow {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle, rgba(255,204,0,0.15) 0%, rgba(0,0,0,0) 70%);
        z-index: -1;
        filter: blur(20px);
    }

    /* Луксозна кутия за часове */
    .premium-showtime-card {
        background: linear-gradient(145deg, #11141a, #161a23);
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 15px 35px rgba(0,0,0,0.6);
    }

    /* Дизайн на интерактивен Кино Билет */
    .showtime-ticket-btn {
        display: flex;
        flex-direction: column;
        background: #1a1f2c;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 16px;
        position: relative;
        text-decoration: none !important;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .showtime-ticket-btn:hover {
        background: #23293a;
        border-color: #ffcc00;
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(255, 204, 0, 0.15);
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .time-display {
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffffff;
    }

    .showtime-ticket-btn:hover .time-display {
        color: #ffcc00;
    }

    .hall-badge {
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.05);
        color: #a0aec0;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: 600;
        text-uppercase;
    }

    .ticket-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px dashed rgba(255, 255, 255, 0.1);
        padding-top: 10px;
        font-size: 0.8rem;
    }

    .date-display {
        color: #718096;
    }

    .price-display {
        color: #48bb78;
        font-weight: 700;
    }

    /* Странични перфорации на билета */
    .ticket-cutout-left, .ticket-cutout-right {
        position: absolute;
        top: 55%;
        width: 10px;
        height: 14px;
        background: #11141a; 
        border-radius: 10px;
    }
    .ticket-cutout-left { left: -5px; border-radius: 0 10px 10px 0; }
    .ticket-cutout-right { right: -5px; border-radius: 10px 0 0 10px; }

    .description-text {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #cbd5e0;
    }
</style>