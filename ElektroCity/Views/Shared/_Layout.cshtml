<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElektroCity</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-black text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom border-secondary box-shadow mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-warning text-uppercase" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: 1px;">⚡ ElektroCity</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Movies" asp-action="Index">Филми</a>
                        </li>
                        <li class="nav-item">
    <a class="nav-link text-light" asp-controller="Screenings" asp-action="Create">Добави Прожекция</a>
</li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @using Microsoft.AspNetCore.Http
                        @inject IHttpContextAccessor HttpContextAccessor
                        @{
                            var userEmail = HttpContextAccessor.HttpContext?.Session.GetString("UserEmail");
                        }

                        @if (!string.IsNullOrEmpty(userEmail))
                        {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-warning fw-bold btn btn-outline-secondary px-3" 
                                       href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-color: #ffcc00; color: #ffcc00 !important;">
                                        ⚡ @userEmail
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary shadow-lg custom-dropdown" aria-labelledby="profileDropdown">
                                        <li>
                                            <a class="dropdown-item text-light py-2" asp-controller="Reservation" asp-action="MyReservations">
                                                🎬 Моите Резервации
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider border-secondary"></li>
                                        <li>
                                            <a class="dropdown-item text-danger py-2" asp-controller="Account" asp-action="Logout">
                                                ❌ Изход
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                        }
                        else
                        {
                                <li class="nav-item">
                                    <a class="nav-link text-light fw-bold px-3 me-2" asp-controller="Account" asp-action="Login">Вход</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn fw-bold px-3" asp-controller="Account" asp-action="Register" style="background-color: #ffcc00; color: #000;">Регистрация</a>
                                </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <style>
        /* Използваме двойно @@, за да не го бърка Razor с C# код */
        .custom-dropdown.show {
            animation: fadeIn 0.25s ease-out forwards;
        }

        @@keyframes fadeIn {
            from { 
                opacity: 0; 
                transform: translateY(10px); 
            }
            to { 
                opacity: 1; 
                transform: translateY(0); 
            }
        }

        .dropdown-item:hover {
            background-color: #ffcc00 !important;
            color: #000 !important;
            transition: background-color 0.2s ease;
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>